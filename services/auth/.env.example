AUTH_GRPC_PORT=:50051
DB_URI=postgres://auth_user:auth_password@localhost:5433/auth?sslmode=disable
REDIS_ADDR=localhost:6379
KAFKA_BROKERS=localhost:9093
KAFKA_TOPIC=user-registered

OUTBOX_POLL_INTERVAL=2s
OUTBOX_CLEANUP_INTERVAL=60s
OUTBOX_FETCH_LIMIT=100

LOGGER_LEVEL=info
LOGGER_AS_JSON=false

OTEL_COLLECTOR_ENDPOINT=localhost:4317
OTEL_SERVICE_NAME=auth
OTEL_ENVIRONMENT=local
OTEL_SERVICE_VERSION=0.1.0

JWT_SECRET=secret
ACCESS_TOKEN_TTL=10m
REFRESH_TOKEN_TTL=240h
