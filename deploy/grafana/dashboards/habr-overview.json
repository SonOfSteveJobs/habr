      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.3 }, { "color": "red", "value": 0.5 }] } } },
      "options": { "displayMode": "lcd", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "bargauge", "title": "HTTP Latency p99 by Path",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "histogram_quantile(0.99, sum(rate(http_server_duration_seconds_bucket[5m])) by (le, http_path))", "legendFormat": "{{http_path}}", "instant": true }],
